  "keyFeatures": [
    "Automatic service discovery and configuration",
    "Support for Docker, Kubernetes, Consul, etcd, and more",
    "Built-in Let's Encrypt support for automatic HTTPS",
    "Multiple load balancing algorithms",
    "HTTP/2, gRPC, and WebSocket support",
    "Middleware system for request/response manipulation",
    "Circuit breakers and retry mechanisms",
    "Real-time metrics and observability",
    "Web dashboard for monitoring",
    "Plugin system for extensibility"
  ],
  "publicApiSurface": [
    "EntryPoints - Network entry points (HTTP, HTTPS, TCP, UDP)",
    "Routers - Request routing based on rules",
    "Services - Backend service configuration and load balancing",
    "Middlewares - Request/response manipulation",
    "Providers - Docker, Kubernetes, File, Consul, etcd, ECS",
    "ACME - Automatic certificate management",
    "Metrics - Prometheus, Datadog, StatsD, InfluxDB",
    "Tracing - Jaeger, Zipkin, OpenTelemetry",
    "API - REST API for configuration and monitoring",
    "Dashboard - Web UI for visualization"
